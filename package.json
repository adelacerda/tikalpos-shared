{
  "name": "@tikalpos/shared",
  "version": "0.1.25",
  "description": "Shared TypeScript type definitions and utilities for Tikal POS.",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/cjs/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/cjs/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "license": "MIT",
  "author": "adelacerda",
  "repository": {
    "type": "git",
    "url": "https://github.com/adelacerda/tikalpos-shared.git"
  },
  "homepage": "https://github.com/adelacerda/tikalpos-shared",
  "keywords": [
    "pos",
    "point-of-sale",
    "types",
    "typescript",
    "shared",
    "tikal-pos"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.cjs.json && tsc -p tsconfig.esm.json",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "tsc -p tsconfig.cjs.json --watch",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "typescript": "~5.9.2",
    "vitest": "^1.6.1"
  }
}
